---
---

<footer class="glass section-spacing">
  <div class="container footer-wrapper">
    <div class="footer-brand">
      <div class="logo">
        <span class="gradient-text">TimeCup</span> League
      </div>
      <p class="footer-description">
        La primera liga online y presencial de Cross Training en formato competitivo.
        Temporadas de 3 meses, categorías por nivel y equipos de 3 personas.
      </p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Competición</h4>
        <a href="#how">Cómo funciona</a>
        <a href="#categories">Categorías</a>
        <a href="#chronogram">Calendario</a>
      </div>
      <div class="link-group">
        <h4>Entrenamientos</h4>
        <a href="#results">Resultados</a>
        <a href="#boxes">Boxes Afiliados</a>
        <a href="#store">Tienda</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} TimeCup League. Todos los derechos reservados.</p>
      <div class="social-links">
        <a href="https://instagram.com/timecupleague" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://tiktok.com/@timecupleague" target="_blank" rel="noopener noreferrer">TikTok</a>
        <a href="https://youtube.com/timecupleague" target="_blank" rel="noopener noreferrer">YouTube</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 5rem;
    padding: 5rem 0 3rem;
    border-radius: 40px 40px 0 0;
  }

  .footer-wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .footer-brand .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -1.5px;
    margin-bottom: 1.5rem;
    color: white;
  }

  .footer-description {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 450px;
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
  }

  .footer-links h4 {
    margin-bottom: 1.5rem;
    color: white;
    font-size: 1.1rem;
    letter-spacing: 0.5px;
  }

  .link-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .link-group a {
    font-size: 0.95rem;
    color: var(--text-muted);
    transition: var(--transition);
  }

  .link-group a:hover {
    color: var(--accent);
    transform: translateX(5px);
  }

  .footer-bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 3rem;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-links a {
    color: var(--text-muted);
    font-weight: 500;
  }

  .social-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .footer-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .footer-links {
      flex-direction: column;
      gap: 2.5rem;
    }
    .footer-bottom {
      flex-direction: column-reverse;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>
