---
import Layout from '../layouts/Layout.astro'
import Header from '../components/sections/Header.astro'
import Footer from '../components/sections/Footer.astro'
---

<Layout title="Email Confirmado - TimeCup League">
  <Header />
  <main>
    <section class="hero-small" style="height: 100vh;">
      <div class="hero-content" style="flex-direction: column; text-align: center;">
        <div style="margin-bottom: 2rem;">
          <svg style="width: 64px; height: 64px; margin: 0 auto; color: #4ade80;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>

        <h1 style="text-transform: none; font-size: 3rem;">Email Confirmado</h1>

        <p style="font-size: 1.25rem; color: #ccc; margin-bottom: 1.5rem;">
          Tu dirección de correo electrónico ha sido confirmada correctamente.
        </p>

        <p style="font-size: 1rem; color: #aaa; margin-bottom: 2rem;">
          Ya puedes acceder a todas las funcionalidades de TimeCup League desde la app.
        </p>

        <a href="/" class="btn-primary" style="display: inline-block;">
          Volver al inicio
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
